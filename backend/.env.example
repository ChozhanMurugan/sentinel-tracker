# ── Environment variables ─────────────────────────────────────────
# Copy this to .env and fill in your values

# Database (TimescaleDB — starts with docker-compose up)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_pass@localhost:5432/sentinel

# Redis (starts with docker-compose up)
REDIS_URL=redis://localhost:6379

# OpenSky Network — optional but gives 10x more requests/day
# Register free at https://opensky-network.org
OPENSKY_USER=
OPENSKY_PASS=

# aisstream.io API key — for ship tracking
# Get free at https://aisstream.io
AIS_KEY=

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# How often to poll OpenSky (seconds). Min 5 for anonymous, 2 for registered
OPENSKY_REFRESH_S=5

# How many seconds before an aircraft is considered stale and removed
STALE_THRESHOLD_S=90

# CORS — add your frontend URL
CORS_ORIGINS=["http://localhost:8787","http://127.0.0.1:8787","http://localhost:5500","http://127.0.0.1:5500"]
